# Sao chép file này thành .env rồi chỉnh giá trị. Tất cả đều TÙY CHỌN.
# Khuyến nghị: đặt API key trực tiếp trong app (nút Settings) — key lưu vào
# data.db. Các biến GEMINI_API_KEY / OPENAI_API_KEY dưới đây chỉ là fallback
# nếu chưa cấu hình trong Settings.

# --- API keys (fallback, để trống nếu đã nhập trong Settings của app) ---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- ComfyUI (Stable Diffusion local) ---
# URL server ComfyUI đang chạy. Mặc định: http://127.0.0.1:8188
COMFYUI_URL=http://127.0.0.1:8188

# --- Codex (đăng nhập ChatGPT OAuth) ---
# File token OAuth dùng chung với Codex CLI. Mặc định: ~/.codex/auth.json
# CODEX_AUTH_FILE=
# CODEX_DEBUG=1 → ghi log request/response (SSE) provider codex vào logs/codex/
CODEX_DEBUG=

# --- Cache ---
# Ngưỡng tổng dung lượng blobs cache (bytes); vượt thì tự xóa blob cũ nhất.
# Mặc định: 524288000 (500 MB)
CACHE_MAX_BYTES=524288000
